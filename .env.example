# ══════════════════════════════════════════════════════════════════════
#  SubsGen — Environment Variables
#  Copy this file to .env and fill in your keys
#  Never commit .env to git
# ══════════════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────────────
#  GROQ API KEYS  (3 keys = 3x free quota via key rotation)
#
#  Get free keys at: https://console.groq.com
#  One key per Gmail account — free tier is very generous
#
#  Used for:
#    GROQ_API_KEY_1 → Agent 1: Whisper Large v3  (speech-to-text)
#    GROQ_API_KEY_2 → Agent 2: Llama 4 Scout VLM (visual analysis)
#    GROQ_API_KEY_3 → Agent 3+4: Llama 3.3 70B   (brain + music planning)
#  Keys rotate round-robin so no single key gets rate-limited
# ──────────────────────────────────────────────────────────────────────

GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx





# ══════════════════════════════════════════════════════════════════════
#  MODEL REFERENCE  (no config needed — just for your info)
# ══════════════════════════════════════════════════════════════════════
#
#  Agent 1  — Speech-to-Text
#             Model:   whisper-large-v3
#             Where:   Groq API (free)
#             Purpose: Transcribe each clip with word-level timestamps
#
#  Agent 2  — Vision Language Model (VLM)
#             Model:   meta-llama/llama-4-scout-17b-16e-instruct
#             Where:   Groq API (free)
#             Purpose: Analyze sampled frames — mood, energy, lighting, quality
#
#  Agent 3  — The Brain (LLM Director)
#             Model:   llama-3.3-70b-versatile
#             Where:   Groq API (free)
#             Purpose: Read transcripts + VLM data → decide clip order,
#                      exact trim points, subtitle style, caption + hashtags
#
#  Agent 4  — Music Supervisor (LLM + API)
#             Model:   llama-3.3-70b-versatile  (Groq, free)
#             API:     Internet Archive        (free, CC0, no key)
#             Purpose: Refine music query → search → pick best track → download
#
#  Producer — FFmpeg (local, no API)
#             Purpose: Precise trim, 9:16 reframe, crossfade concat,
#                      music mix, subtitle burn
#
# ══════════════════════════════════════════════════════════════════════
#  HUGGING FACE SPACES DEPLOYMENT
#
#  Add all keys above as Secrets in your HF Space:
#  Space → Settings → Variables and Secrets → New Secret
#
#  DO NOT put keys in plain Variables — use Secrets only
# ══════════════════════════════════════════════════════════════════════
